# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit real credentials.

POSTGRES_USER=polymarket
POSTGRES_PASSWORD=polymarket
POSTGRES_DB=polymarket
POSTGRES_HOST=localhost   # use 'postgres' when running inside Docker
POSTGRES_PORT=5432

# Optional: set to 'true' to enable DEBUG-level logging (per-request details)
DEBUG=false

# CSV file of event IDs to fetch from Polymarket Gamma API.
# Mounted as /data/ in Docker via docker-compose.yml.
EVENT_IDS_PATH=/data/football_event_ids_500.csv

# Reduced from 30 — with 10k events the higher value triggers heavy 429s.
MAX_CONCURRENT_REQUESTS=20

# Raised from 3 — gives persistent 429s more chances to succeed.
MAX_RETRIES=5
